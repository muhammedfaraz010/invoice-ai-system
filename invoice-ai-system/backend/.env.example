# ============================================================
# INVOICE AI SYSTEM - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your actual values

# --- Groq ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI (optional, used by some modules) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# --- Pinecone Vector DB ---
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=invoice-embeddings

# --- PostgreSQL Database ---
DATABASE_URL=postgresql://invoice_user:invoice_pass@localhost:5432/invoice_db

# --- Security ---
SECRET_KEY=your_super_secret_jwt_key_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Storage ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# --- App ---
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# --- Email Alerts (Optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=finance@yourcompany.com
